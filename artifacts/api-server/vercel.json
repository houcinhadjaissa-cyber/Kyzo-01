{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": ".",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "api/index.mjs": {
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ]
}
