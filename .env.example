# AIOS API Server — Environment Variables
# Copy this file to .env and fill in values for local development
# Never commit .env to version control

# ── Server ─────────────────────────────────────────────
NODE_ENV=development           # development | production | test
PORT=3000                      # Local server port (Vercel ignores this)

# ── CORS (production only) ──────────────────────────────
ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com

# ── AI Providers (choose one or more) ──────────────────
OPENROUTER_API_KEY=sk-or-...   # https://openrouter.ai — free tier available
OPENAI_API_KEY=sk-...          # Optional: direct OpenAI access
ANTHROPIC_API_KEY=sk-ant-...   # Optional: direct Anthropic access

# ── Push Notifications ──────────────────────────────────
EXPO_ACCESS_TOKEN=             # https://expo.dev/accounts/[user]/settings/access-tokens

# ── Deployment Providers ────────────────────────────────
VERCEL_TOKEN=                  # https://vercel.com/account/tokens
VERCEL_ORG_ID=                 # Found in Vercel project settings
VERCEL_PROJECT_ID=             # Found in Vercel project settings

# ── Analytics / Monitoring (optional) ──────────────────
SENTRY_DSN=                    # https://sentry.io — free tier available

# ── Feature Flags ───────────────────────────────────────
ENABLE_RATE_LIMITING=true
ENABLE_SECURITY_HEADERS=true
